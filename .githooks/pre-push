#!/bin/sh
set -eu

git_path="$(command -v git || true)"
git_dir="${git_path%/*}"
git_usr_bin="$git_dir/../usr/bin"
if [ -n "$git_path" ] && [ -d "$git_usr_bin" ]; then
  PATH="$git_usr_bin:$PATH"
  export PATH
fi

zero_sha='0000000000000000000000000000000000000000'
all_changed_files=''
cr="$(printf '\r')"

append_changed_files() {
  range="$1"
  diff_output="$(git diff --name-only "$range" || true)"
  if [ -z "$diff_output" ]; then
    return 0
  fi

  if [ -n "$all_changed_files" ]; then
    all_changed_files="$(printf '%s\n%s\n' "$all_changed_files" "$diff_output")"
  else
    all_changed_files="$diff_output"
  fi
}

has_changed() {
  printf '%s\n' "$all_changed_files" | grep -Eq "$1"
}

run_check() {
  description="$1"
  command="$2"

  echo "Running [$description]"
  echo "  $command"
  sh -c "$command"
}

while read -r local_ref local_sha remote_ref remote_sha
do
  local_ref="${local_ref%"$cr"}"
  local_sha="${local_sha%"$cr"}"
  remote_ref="${remote_ref%"$cr"}"
  remote_sha="${remote_sha%"$cr"}"

  [ -n "${local_ref:-}" ] || continue

  if [ "$local_sha" = "$zero_sha" ]; then
    continue
  fi

  if [ "$remote_sha" = "$zero_sha" ]; then
    merge_base="$(git merge-base "$local_sha" origin/main 2>/dev/null || true)"
    if [ -n "$merge_base" ]; then
      append_changed_files "$merge_base..$local_sha"
    else
      echo "WARNING: Could not resolve origin/main merge-base for $local_ref. Skipping new-branch diff."
    fi
    continue
  fi

  append_changed_files "$remote_sha..$local_sha"
done

all_changed_files="$(printf '%s\n' "$all_changed_files" | sed '/^$/d' | sort -u)"

if [ -z "$all_changed_files" ]; then
  echo "ArticleShelf pre-push: no changed files detected for pushed refs."
  exit 0
fi

echo "ArticleShelf pre-push: detected changed paths:"
printf '%s\n' "$all_changed_files" | sed 's/^/  - /'

run_frontend_auth_checks=false
run_mobile_e2e=false
run_composable_tests=false
run_backend_architecture=false
run_backend_check=false

if has_changed '^(frontend/playwright\.config\.ts|frontend/e2e/.*|frontend/scripts/e2e-webserver\.(mjs|sh)|docker-compose\.e2e\.yml|frontend/src/app/providers/router\.ts|frontend/src/features/auth/.*|frontend/src/features/articles/composables/useWorkspaceAccountActions\.ts|frontend/src/features/articles/views/ArticleWorkspace\.vue)$'; then
  run_frontend_auth_checks=true
fi

if has_changed '^(frontend/e2e/mobile-responsive\.spec\.ts|frontend/src/features/articles/components/.*|frontend/src/styles/.*)$'; then
  run_mobile_e2e=true
fi

if has_changed '^frontend/src/features/articles/composables/.*$'; then
  run_composable_tests=true
fi

if has_changed '^(backend/src/main/java/com/articleshelf/domain/.*|backend/src/main/java/com/articleshelf/application/.*|backend/src/test/java/com/articleshelf/architecture/.*)$'; then
  run_backend_architecture=true
fi

if has_changed '^(backend/pom\.xml|backend/src/main/java/com/articleshelf/infrastructure/.*|backend/src/main/java/com/articleshelf/adapter/.*|backend/src/main/java/com/articleshelf/domain/.*Repository[^/]*\.java|backend/src/test/java/.*)$'; then
  run_backend_check=true
fi

if [ "$run_frontend_auth_checks" = false ] && [ "$run_mobile_e2e" = false ] && [ "$run_composable_tests" = false ] && [ "$run_backend_architecture" = false ] && [ "$run_backend_check" = false ]; then
  echo "ArticleShelf pre-push: no targeted verification rules matched."
  exit 0
fi

if [ "$run_frontend_auth_checks" = true ]; then
  run_check \
    "frontend auth/router targeted unit tests" \
    "cd frontend && npm run test:unit -- src/features/articles/composables/useWorkspaceAccountActions.test.ts src/features/auth/components/AuthScreen.test.ts"
  run_check \
    "frontend authenticated article smoke E2E" \
    "cd frontend && npx playwright test e2e/authenticated-articles.spec.ts -g \"user can register, create an article, logout and login again\""
fi

if [ "$run_mobile_e2e" = true ]; then
  run_check \
    "frontend mobile shell smoke E2E" \
    "cd frontend && npx playwright test e2e/mobile-responsive.spec.ts -g \"mobile drawer and bottom navigation reach primary screens\""
fi

if [ "$run_composable_tests" = true ]; then
  run_check \
    "frontend article composable targeted unit tests" \
    "cd frontend && npm run test:unit -- src/features/articles/composables/useTagActions.test.ts src/features/articles/composables/useWorkspaceAccountActions.test.ts"
fi

if [ "$run_backend_architecture" = true ]; then
  run_check \
    "backend clean architecture dependency test" \
    "docker compose run --rm backend mvn test -Dtest=CleanArchitectureDependencyTest"
fi

if [ "$run_backend_check" = true ]; then
  run_check \
    "backend spotbugs and test gate" \
    "docker compose run --rm backend mvn test spotbugs:check"
fi

echo "ArticleShelf pre-push checks passed."
