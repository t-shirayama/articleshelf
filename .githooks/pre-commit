#!/bin/sh
set -eu

changed_files="$(git diff --cached --name-only)"

if [ -z "$changed_files" ]; then
  exit 0
fi

has_changed() {
  printf '%s\n' "$changed_files" | grep -Eq "$1"
}

has_staged_content() {
  git diff --cached --name-only -- "$@" | grep -q .
}

echo "Running ReadStack pre-commit checks..."

if has_changed '^frontend/src/.*\.(vue|ts|css)$'; then
  echo "Frontend source changed: running frontend typecheck."
  (cd frontend && npm run typecheck --silent)
fi

if has_changed '^frontend/src/.*\.(vue|ts|css)$'; then
  if ! has_changed '^(docs/design\.md|docs/specification/ui\.md)$'; then
    echo "WARNING: UI files changed without docs/design.md or docs/specification/ui.md."
    echo "         If the visual behavior changed, update the relevant UI docs before committing."
  fi
fi

if has_staged_content '*.md' '*.yml' '*.yaml' '*.sh' '*.ps1' '*.bat' '*.cmd'; then
  if git diff --cached -U0 -- '*.md' '*.yml' '*.yaml' '*.sh' '*.ps1' '*.bat' '*.cmd' \
    | grep -E '^\+[^+].*(^|[^A-Za-z0-9_-])mvn([[:space:]]|$)' \
    | grep -Ev 'docker compose (exec|run).*mvn' >/dev/null; then
    echo "ERROR: Local mvn command found in staged changes."
    echo "       Use Docker-based Maven commands, for example:"
    echo "       docker compose run --rm backend mvn test"
    exit 1
  fi
fi

echo "ReadStack pre-commit checks passed."
